theme = Atom One Dark

# Quick terminal (popup terminal with global hotkey)
keybind = global:ctrl+grave_accent=toggle_quick_terminal
quick-terminal-size = 50%
quick-terminal-animation-duration = 0

# Remap Cmd-a to Ctrl-a for tmux prefix
keybind = cmd+a=text:\x01
# Remap Cmd-e to Ctrl-e for the nested inner tmux prefix (~/.tmux.inner.conf).
keybind = cmd+e=text:\x05

# Send Ctrl+Arrow CSI sequences for word motion. Karabiner remaps
# Cmd+arrow → Option+arrow globally, so Ghostty actually receives Option+arrow
# even when we physically press Cmd+arrow — hence binding alt+ here, not cmd+.
# (The cmd+ bindings are kept as a fallback in case the Karabiner rule is off.)
keybind = alt+arrow_left=csi:1;5D
keybind = alt+arrow_right=csi:1;5C
keybind = alt+shift+arrow_left=csi:1;6D
keybind = alt+shift+arrow_right=csi:1;6C
keybind = cmd+arrow_left=csi:1;5D
keybind = cmd+arrow_right=csi:1;5C
keybind = cmd+shift+arrow_left=csi:1;6D
keybind = cmd+shift+arrow_right=csi:1;6C

# Forward Cmd+C as Ctrl+C so nvim can map <C-c> to copy the nvim
# selection (default ghostty behavior copies the terminal selection,
# not the nvim selection). nvim's <C-c> mappings override what would
# otherwise be the "abort" default in each mode.
keybind = cmd+c=text:\x03

# Forward Cmd+Z as Ctrl+Z so nvim's <C-z> = undo mapping fires.
keybind = cmd+z=text:\x1a

# Forward Cmd+Shift+F as the CSI-u sequence for Ctrl+Shift+F so nvim's
# <C-S-f> mapping fires regardless of whether Karabiner intercepts the
# Cmd key.
keybind = cmd+shift+f=csi:102;6u

# Forward Cmd+/ and Ctrl+/ as 0x1F (= <C-_> in Neovim) so the nvim
# comment-toggle mapping fires. Without this Ghostty's default for
# Cmd+/ either gets eaten by macOS (Help menu) or arrives as a bare `/`,
# and Ctrl+/ on the built-in keyboard isn't forwarded as 0x1F either.
keybind = cmd+slash=text:\x1f
keybind = ctrl+slash=text:\x1f

# Forward Cmd+X as Ctrl+X so nvim's <C-x> = cut mapping fires.
keybind = cmd+x=text:\x18

# Forward Cmd+S as Ctrl+S so LazyVim's <C-s> = :w mapping fires.
keybind = cmd+s=text:\x13

# Forward Cmd+D as Ctrl+D so nvim's multicursor (<C-d>) fires. Overrides
# Ghostty's default cmd+d=new_split:right. Needed on keyboards where
# Karabiner isn't swapping Cmd↔Ctrl (built-in Mac keyboard).
keybind = cmd+d=text:\x04
keybind = cmd+shift+d=csi:100;6u

# Forward Cmd+[ / Cmd+] as Ctrl+Shift+[ / ] CSI-u sequences (modifier 6)
# so nvim's <C-S-[> / <C-S-]> mappings fire — used by file-history.lua.
# 91/93 are codepoints for `[`/`]`.
# We can't use the natural Super (=9) modifier because tmux 3.5a strips
# CSI-u sequences with modifier > 8; modifier 6 (Ctrl+Shift) passes through
# unmangled (same mechanism as cmd+shift+f=csi:102;6u above).
# We also bind the Ctrl variants: Karabiner swaps Left-Cmd↔Left-Ctrl on
# PC keyboards, so physical "Cmd"+[ arrives at Ghostty as Ctrl+[ on those.
# Overriding Ctrl+[ would normally break ESC, but Caps Lock → Escape
# (also via Karabiner) covers that.
keybind = cmd+bracket_left=csi:91;6u
keybind = cmd+bracket_right=csi:93;6u
keybind = ctrl+bracket_left=csi:91;6u
keybind = ctrl+bracket_right=csi:93;6u

# Send the CSI-u sequence for Ctrl+Enter so nvim's <C-CR> mapping fires.
# (By default terminals deliver Ctrl+Enter as a plain CR.)
keybind = ctrl+enter=csi:13;5u
# Same for cmd+enter — built-in Mac keyboard doesn't get the Karabiner
# Cmd↔Ctrl swap, so forward Cmd+Enter as if it were Ctrl+Enter too.
keybind = cmd+enter=csi:13;5u

# Allow OSC52 clipboard writes without prompting. tmux (`set-clipboard on`)
# uses OSC52 to push mouse-drag selections into the macOS clipboard, including
# from nested inner tmux sessions. Default is `ask`, which silently fails if
# the prompt is dismissed.
clipboard-write = allow
