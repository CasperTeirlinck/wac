# Passthrough of prefix combinations to vim
# See: https://github.com/christoomey/vim-tmux-navigator
is_vim="ps -o state= -o comm= -t '#{pane_tty}' \
    | grep -iqE '^[^TXZ ]+ +(\\S+\\/)?g?(view|l?n?vim?x?)(diff)?$'"
# Same idea for an inner tmux client (launched via `tmi` on the `inner` socket)
# running in the active pane — match a foreground process whose comm is
# `tmux`, optionally with a `: client` / `: server` suffix. macOS reports the
# bare `tmux` in comm, but Linux tmux calls setproctitle() and ps shows
# `tmux: client` for the client process; without the optional `(:.*)?` tail
# the regex would miss on Linux/WSL and `C-a x` etc. would fall through to
# the outer pane instead of being forwarded to the inner tmux.
is_inner_tmux="ps -o state= -o comm= -t '#{pane_tty}' \
    | grep -iqE '^[^TXZ ]+ +(\\S+\\/)?tmux(:.*)?$'"

# Format-based "vim OR inner-tmux" detector for the HELD scroll chord
# (C-Up/C-Down). The $is_vim / $is_inner_tmux pipelines above shell out to
# `ps` on every invocation — fine for a one-shot prefix key, but when you
# HOLD C-Up/C-Down the OS key-repeat fires this dozens of times a second,
# each spawning a subprocess. tmux serialises them and you get seconds of
# laggy, jittery "replayed" scrolling (the mouse wheel skips this binding
# entirely, which is why it's always smooth). This matches
# pane_current_command via a tmux format instead — evaluated internally,
# zero subprocesses — so a held key stays cheap. Use with `if-shell -F`.
is_vim_or_inner_f="#{m/ri:^(g?(view|l?n?vim?x?)(diff)?|tmux(:.*)?)$,#{pane_current_command}}"

# Low but non-zero: at 1ms tmux forwards a lone Esc before the rest of a
# multi-byte sequence arrives, so terminal query/resize *responses* (e.g.
# the cursor-position report tmux relays on a `prefix-z` zoom) get split —
# the printable tail then leaks into the pane and, in nvim Select mode,
# replaces the selection. 10ms keeps such sequences intact without making
# Esc feel laggy.
set -s escape-time 10

# Forward terminal focus events so nvim's FocusGained/FocusLost fire when
# switching between tmux panes (needed for the nvim git sidebar to refresh
# after running git commands in another pane).
set -g focus-events on

# Extended keys for Shift+Enter, etc. (needed for Claude Code in tmux)
set -s extended-keys on
set -as terminal-features 'xterm*:extkeys,screen*:extkeys'

# Pass Shift+Enter to applications (for Claude Code multi-line input)
bind-key -n S-Enter send-keys Escape "[13;2u"

# Pass Ctrl+Enter through as CSI-u so nvim's <C-CR> mapping fires.
bind-key -n C-Enter send-keys Escape "[13;5u"

# Colors
set -g default-terminal "screen-256color"
set-option -sa terminal-overrides ",xterm*:Tc"

# OSC 8 hyperlink passthrough — lets programs (gh, eza, lazygit, …) emit
# clickable links that survive tmux and reach Ghostty's URL handler.
# Inside tmux mouse mode, hold Shift while clicking to bypass tmux's mouse
# capture (Cmd+Shift+click opens the link on macOS).
set -as terminal-features ',*:hyperlinks'

# Kitty graphics protocol passthrough — lets nvim (snacks.image) render
# PNG/JPG/SVG/PDF inline by sending the escapes straight to Ghostty.
# Without this, tmux swallows the graphics bytes and snacks reports
# "terminal does not support kitty graphics".
set -g allow-passthrough on

# Status bar
set-option -g status-position bottom
set-option -g status-justify left

# Track the active window's index in @active_window_index so the powerline
# theme can render a vim/lualine-style transition cap on the inactive tab that
# precedes the active one (its trailing cap fg becomes the active tab's bg,
# bridging the colour change smoothly). `set-option` doesn't expand format
# strings in its value, so we round-trip through `run-shell` which does — the
# resulting command stores the *expanded* index, not the literal
# `#{window_index}`. We run synchronously (no `-b`) so the option is in place
# before tmux redraws the status bar after the hook fires; with `-b` the
# initial post-attach render uses the stale seeded `1`, and the bridge cap
# only appears after the user manually switches a tab.
set -g @active_window_index 1
set-hook -g session-window-changed 'run-shell "tmux set -g @active_window_index #{window_index}"'
set-hook -g client-attached        'run-shell "tmux set -g @active_window_index #{window_index}"'
set-hook -g after-select-window    'run-shell "tmux set -g @active_window_index #{window_index}"'

# Scroll length
set-option -g history-limit 10000

# Mouse
set -g mouse on

# Mouse wheel: scroll 1 line per tick in copy-mode (default is 5).
bind-key -T copy-mode-vi WheelUpPane send-keys -X -N 1 scroll-up
bind-key -T copy-mode-vi WheelDownPane send-keys -X -N 1 scroll-down
bind-key -T copy-mode WheelUpPane send-keys -X -N 1 scroll-up
bind-key -T copy-mode WheelDownPane send-keys -X -N 1 scroll-down

# Clipboard: mouse-drag selects → release copies to system clipboard via OSC52.
# Ghostty natively accepts OSC52; with `set-clipboard on` the outer tmux also
# forwards OSC52 emitted by a nested inner tmux up to Ghostty.
# NOTE: the feature pattern must match `default-terminal` (screen-256color),
# not Ghostty's outer $TERM — tmux uses its own TERM when adding the `Ms`
# terminfo cap that enables OSC52 emission.
set -g set-clipboard on
set -as terminal-features 'screen*:clipboard'
bind-key -T copy-mode    MouseDragEnd1Pane send-keys -X copy-selection-and-cancel
bind-key -T copy-mode-vi MouseDragEnd1Pane send-keys -X copy-selection-and-cancel

# Prefix
{{$prefix := ""}}
{{ if eq .chezmoi.os "darwin" }}
# tmux only supports binding to Meta or Ctrl where Meta = Alt on Mac.
# so instead, keep the modifier to Ctrl, and remap Cmd-a to Ctrl-a in the terminal.
# Ghostty: keybind = cmd+a=text:\x01
# iTerm: profile -> Keys -> Key Mappings -> map Cmd-a to send hex code 0x01
{{$prefix = "C-a"}}
{{ else if eq .chezmoi.os "linux" }}
{{$prefix = "C-a"}}
{{ end }}
set -g prefix {{$prefix}}
unbind C-b
bind-key {{$prefix}} send-prefix

# Splitting
unbind \\
unbind '"'
bind \\ split-window -h -c "#{pane_current_path}"
bind - split-window -v -c "#{pane_current_path}"

# Start windows and panes at 1
set -g base-index 1
set -g pane-base-index 1
set-window-option -g pane-base-index 1
set-option -g renumber-windows on

# Tab formatting
set-option -g status-interval 5
set-option -g automatic-rename on
set-window-option -g window-status-style fg=white,bg=default
set-window-option -g window-status-current-style fg=#000000,bg=default
# tmux's default window-status-separator is a literal " " (one space) inserted
# between each tab's render. With the lualine-style caps we draw ourselves
# that space appears as a 1-cell gap with bg=default between the bridge cap
# and the active tab's body (the cap can't connect into the active tab's bg).
# Empty separator → caps render flush against the next tab; the thin-cap
# glyph between two inactive tabs still provides visual separation.
set-window-option -g window-status-separator ''
set-option -g automatic-rename-format '#{P:#{?#{!=:#{b:pane_current_path},casper},#{b:pane_current_path},~}#{?#{!=:#{pane_current_command},zsh}, #[fg=green]#{pane_current_command}#[fg=default],}#{?#{!=:#{pane_index},#{window_panes}}, | ,},#[bold]#{?#{!=:#{b:pane_current_path},casper},#{b:pane_current_path},~}#{?#{!=:#{pane_current_command},zsh}, #[fg=green]#{pane_current_command}#[fg=default],}#[nobold]#{?#{!=:#{pane_index},#{window_panes}}, | ,}}'

# Moving between panes
unbind Up
unbind Down
unbind Left
unbind Right
# Order: vim → inner tmux → outer select-pane. Vim gets the prefix+arrow it
# expects ({{$prefix}}); an inner tmux gets C-e+arrow (its own prefix) so its
# matching bindings then run select-pane inside the inner server.
bind-key Up    if-shell "$is_vim" "send-keys {{$prefix}} Up"    "if-shell \"$is_inner_tmux\" \"send-keys C-e Up\"    \"select-pane -U\""
bind-key Down  if-shell "$is_vim" "send-keys {{$prefix}} Down"  "if-shell \"$is_inner_tmux\" \"send-keys C-e Down\"  \"select-pane -D\""
bind-key Left  if-shell "$is_vim" "send-keys {{$prefix}} Left"  "if-shell \"$is_inner_tmux\" \"send-keys C-e Left\"  \"select-pane -L\""
bind-key Right if-shell "$is_vim" "send-keys {{$prefix}} Right" "if-shell \"$is_inner_tmux\" \"send-keys C-e Right\" \"select-pane -R\""

# Ctrl/Cmd + Up/Down: scroll the active pane back through its output (e.g.
# Claude Code, a TUI, shell scrollback) without reaching for the mouse — the
# same chord that scrolls nvim's viewport. Ghostty forwards Cmd+Up/Down as
# the Ctrl+Up/Down CSI sequences (see ghostty/config), arriving here as
# C-Up/C-Down. Three cases, in order:
#
#   1. vim OR an inner-tmux pane → forward the raw C-Up/C-Down key so that
#      layer handles it: nvim runs its <C-Up>/<C-Down> viewport-scroll
#      keymap, and an inner tmux re-runs this same chain for ITS focused
#      pane (so a Claude Code tab inside the inner server scrolls correctly).
#   2. The focused app has mouse reporting on (mouse_any_flag) → synthesise
#      mouse-wheel events straight to the app, exactly mimicking the physical
#      wheel. This is the Claude Code case: Claude captures the wheel and
#      scrolls ITS OWN conversation. Entering tmux copy-mode here was the bug
#      — that scrolls the raw pane scrollback (the shell + the `claude`
#      command above it), not Claude's history. `\e[<64;1;1M` / `\e[<65;1;1M`
#      are SGR wheel-up / wheel-down at row1,col1; -N 3 sends three notches.
#   3. Plain shell (no mouse) → enter copy-mode (-e: scrolling past the
#      bottom exits) and scroll the terminal scrollback a few lines. C-Down
#      only acts when already in copy-mode (pane_in_mode guard) — at the live
#      prompt there's nothing below. The copy-mode-table bindings below let a
#      repeated press keep scrolling once copy-mode is active (the root -n
#      binding stops firing inside copy-mode).
bind-key -n C-Up   if-shell -F "$is_vim_or_inner_f" "send-keys C-Up"   "if-shell -F '#{mouse_any_flag}' 'send-keys -N 3 Escape \"[<64;1;1M\"' 'copy-mode -e ; send-keys -X -N 3 scroll-up'"
bind-key -n C-Down if-shell -F "$is_vim_or_inner_f" "send-keys C-Down" "if-shell -F '#{mouse_any_flag}' 'send-keys -N 3 Escape \"[<65;1;1M\"' 'if-shell -F \"#{pane_in_mode}\" \"send-keys -X -N 3 scroll-down\"'"
bind-key -T copy-mode-vi C-Up   send-keys -X -N 3 scroll-up
bind-key -T copy-mode-vi C-Down send-keys -X -N 3 scroll-down
bind-key -T copy-mode    C-Up   send-keys -X -N 3 scroll-up
bind-key -T copy-mode    C-Down send-keys -X -N 3 scroll-down

# --- Copy-mode as a traditional "select mode" --------------------------------
# Copy-mode gives a cursor you move through the scrollback as if it were a
# text file, then select + copy. Enter it by scrolling up (C-Up) or `prefix
# [`; once in, these keys mirror the traditional-editor scheme from nvim
# (config/keymaps.lua): arrows + Home/End move, Ctrl+arrow is word motion,
# Shift extends a selection, Ctrl+C copies.
#
# `mode-keys vi` makes copy-mode-vi the active table (default here is emacs
# because EDITOR isn't vi-like). The bindings below override that table.
set -g mode-keys vi

# Enter select-mode explicitly with `prefix v` (mnemonic: visual). Scrolling
# (C-Up) deliberately does NOT switch modes — it just scrolls. `prefix [` is
# taken (window nav), hence v. In an inner-tmux pane, forward `C-e v` so the
# INNER server enters copy-mode on its own focused pane (e.g. a shell tab),
# not on the outer pane that wraps it.
bind-key v if-shell "$is_inner_tmux" "send-keys C-e v" "copy-mode"

# Plain movement collapses any active selection first — an unshifted key
# deselects, exactly like a GUI editor — then moves. clear-selection is a
# no-op when nothing is selected.
bind -T copy-mode-vi Up      send -X clear-selection \; send -X cursor-up
bind -T copy-mode-vi Down    send -X clear-selection \; send -X cursor-down
bind -T copy-mode-vi Left    send -X clear-selection \; send -X cursor-left
bind -T copy-mode-vi Right   send -X clear-selection \; send -X cursor-right
bind -T copy-mode-vi Home    send -X clear-selection \; send -X start-of-line
bind -T copy-mode-vi End     send -X clear-selection \; send -X end-of-line
bind -T copy-mode-vi C-Left  send -X clear-selection \; send -X previous-word
bind -T copy-mode-vi C-Right send -X clear-selection \; send -X next-word

# Shift + movement begins a selection on the first press and extends it on
# the next (moving the cursor while a selection is active grows it) — the
# shifted-arrow behaviour from nvim. selection_present tells us which.
bind -T copy-mode-vi S-Up      if -F "#{selection_present}" "send -X cursor-up"      "send -X begin-selection ; send -X cursor-up"
bind -T copy-mode-vi S-Down    if -F "#{selection_present}" "send -X cursor-down"    "send -X begin-selection ; send -X cursor-down"
bind -T copy-mode-vi S-Left    if -F "#{selection_present}" "send -X cursor-left"    "send -X begin-selection ; send -X cursor-left"
bind -T copy-mode-vi S-Right   if -F "#{selection_present}" "send -X cursor-right"   "send -X begin-selection ; send -X cursor-right"
bind -T copy-mode-vi S-Home    if -F "#{selection_present}" "send -X start-of-line"  "send -X begin-selection ; send -X start-of-line"
bind -T copy-mode-vi S-End     if -F "#{selection_present}" "send -X end-of-line"    "send -X begin-selection ; send -X end-of-line"
bind -T copy-mode-vi C-S-Left  if -F "#{selection_present}" "send -X previous-word"  "send -X begin-selection ; send -X previous-word"
bind -T copy-mode-vi C-S-Right if -F "#{selection_present}" "send -X next-word"      "send -X begin-selection ; send -X next-word"

# Ctrl+C copies the selection to the system clipboard and exits (Ghostty
# forwards Cmd+C as C-c; set-clipboard + OSC52 carry it up to Ghostty — same
# path as the mouse-drag copy above). Enter also copies (tmux default).
bind -T copy-mode-vi C-c send -X copy-selection-and-cancel
# Esc deselects if there's a selection, else leaves copy-mode.
bind -T copy-mode-vi Escape if -F "#{selection_present}" "send -X clear-selection" "send -X cancel"

# Moving panes spatially with prefix + C-Arrow. Must unbind first — tmux's
# defaults bind C-Arrow to resize-pane. We swap with the pane that is
# physically in that direction via the `{dir-of}` pane targets (swap-pane -U/-D
# only walk the pane-index list, so in a 2x2 they'd send the bottom-left pane
# to the top-RIGHT instead of straight up). `-d` keeps the active pane on the
# pane we just moved, so repeated presses keep walking the same pane along.
# At an edge (no pane in that direction) the target doesn't resolve and it's
# a harmless no-op.
unbind C-Left
unbind C-Right
unbind C-Up
unbind C-Down
bind -r C-Left  swap-pane -d -t '{left-of}'
bind -r C-Right swap-pane -d -t '{right-of}'
bind -r C-Up    swap-pane -d -t '{up-of}'
bind -r C-Down  swap-pane -d -t '{down-of}'

# Move panes between windows
bind-key / command-prompt -p "send pane to window:" "join-pane -v -t '%%'"

# Deleting panes
unbind x
# bind-key x kill-pane # no confirm-before because cannot customize (yet) the confirm key
# Same vim → inner-tmux → outer fallthrough as the Arrow chain: in an
# inner-tmux pane, forward C-e x so inner's default `prefix x` (confirm +
# kill-pane) closes the inner pane instead of the outer one wrapping it.
bind-key x if-shell "$is_vim" "send-keys {{$prefix}} x" "if-shell \"$is_inner_tmux\" \"send-keys C-e x\" \"kill-pane\""

# Moving between windows
unbind ,
unbind .
unbind <
unbind >
unbind '['
unbind ']'
unbind '{'
unbind '}'
bind-key -r , previous-window
bind-key -r . next-window
bind-key -r < swap-window -d -t -1
bind-key -r > swap-window -d -t +1
bind-key -r '[' if-shell "$is_vim" "send-keys {{$prefix}} '['" "previous-window"
bind-key -r ']' if-shell "$is_vim" "send-keys {{$prefix}} ']'" "next-window"
bind-key -r '{' if-shell "$is_vim" "send-keys {{$prefix}} '{'" "swap-window -d -t -1"
bind-key -r '}' if-shell "$is_vim" "send-keys {{$prefix}} '}'" "swap-window -d -t +1"

# Resizing panes
unbind S-Up
unbind S-Down
unbind S-Left
unbind S-Right
# Same vim-aware chain as the nav bindings: if the active pane runs vim,
# forward the chord so smart-splits in nvim can resize the nvim window
# (and fall through to tmux's resize-pane when nvim hits the edge).
bind -r S-Up    if-shell "$is_vim" "send-keys {{$prefix}} S-Up"    "resize-pane -U 5"
bind -r S-Down  if-shell "$is_vim" "send-keys {{$prefix}} S-Down"  "resize-pane -D 5"
bind -r S-Left  if-shell "$is_vim" "send-keys {{$prefix}} S-Left"  "resize-pane -L 5"
bind -r S-Right if-shell "$is_vim" "send-keys {{$prefix}} S-Right" "resize-pane -R 5"

unbind m
bind -r m resize-pane -Z

# Window rename: prefix + t prompts for a name, renames the window, and
# disables automatic-rename for it so the custom name sticks (otherwise
# automatic-rename-format would overwrite it every status-interval tick).
# Replaces the default clock-mode binding on `t`.
unbind t
bind-key t command-prompt -p "Rename window:" "rename-window '%%' ; setw automatic-rename off"
bind-key T command-prompt -p "Rename window (styled):" "rename-window '#[fg=green,bold]%%#[fg=default,nobold]' ; setw automatic-rename off"

# Pane border colors
set -g pane-active-border-style fg=white
set -g pane-border-style fg=color236
set -g pane-border-status off

# Highlight color for selection in tree-mode (prefix-w, prefix-s) and
# copy-mode: white-ish bar with dark fg, replacing the harsh default yellow.
set -g mode-style 'fg=#21252b,bg=#abb2bf,bold'

# Prompt + message style (e.g. `prefix t` rename-tab prompt, tmux notifications)
# and command-mode prompt — match the active-tab palette so they read as part
# of the status bar instead of tmux's loud default `bg=yellow,fg=black`.
set -g message-style 'fg=#abb2bf,bg=#3b3f4c'
set -g message-command-style 'fg=#abb2bf,bg=#3b3f4c'

# Config
unbind r
bind r source-file ~/.tmux.conf

# Plugins
set -g @plugin 'tmux-plugins/tpm'
set -g @plugin 'roosta/tmux-fuzzback'
set -g @plugin 'tmux-plugins/tmux-resurrect'
set -g @plugin 'tmux-plugins/tmux-continuum'

set -g @fuzzback-bind /
set -g @fuzzback-popup 1
set -g @fuzzback-fzf-colors 'pointer:2,prompt:4,info:242,gutter:-1'

set -g @resurrect-capture-pane-contents 'on'

# Theme
set -g @plugin 'erikw/tmux-powerline'

# Plugin manager (keep at the bottom)
run '~/.tmux/plugins/tpm/tpm'

# Cheatsheet: prefix-? opens a centered popup listing every prefix binding.
# Placed AFTER tpm so it wins over any plugin (e.g. fuzzback) that tries to
# claim `?` during plugin init. Press q (or Esc) inside `less` to close.
bind-key ? display-popup -E -h 80% -w 80% "tmux list-keys -T prefix | sort | less -R"

# Override window-status formats AFTER the powerline plugin has set its own
# (via tpm `run` above). powerline points window-status-format at
# `#(powerline.sh window-format)`, whose stdout is inserted *literally* into
# the status string by tmux — it isn't recursively re-evaluated, so any
# `#{?...}` conditional inside the script output never fires. Setting the
# format directly here lets the conditional run at render time, which is
# what drives the smooth bridge cap on the inactive tab right before the
# active one.
# The trailing cap is inlined as a single style block + glyph, with each
# attribute *and* the glyph itself selected by `#{?cond,A,B}` rather than
# `#{?cond,#[…bridge…],#[…thin…]}`. Wrapping a whole
# `#[…]` style block in a ternary forces tmux to escape the inner commas as
# `,,` so they don't terminate the branch; tmux 3.5 unescapes them before
# parsing the style, but tmux 3.6 leaves the `,,` in place, the style parser
# hits empty attribute tokens, and the tail of the style (`nounderscore]`)
# renders as literal text on the inactive tab before the active one. Keeping
# each conditional branch comma-free (a single colour or a single glyph)
# sidesteps the escape entirely. Branches: bridge cap is  (right-
# bulging filled, U+E0B4 — same glyph as the active tab's right cap) over
# fg=#21252b/bg=#3b3f4c. The disc fills the LEFT half of the cell in
# #21252b (the onedark/Atom One Dark dark accent — the user matches their
# terminal bg to this hex on both Mac (Ghostty Atom One Dark) and Windows
# Terminal; update if the terminal bg ever changes) so it visually blends
# into terminal bg as a 'cutout', while the cell bg on the RIGHT half is
# #3b3f4c so it connects into the active tab body. Thin cap is  (right-
# bulging outline, U+E0B5) over fg=#5c6370/bg=default — a subtle separator
# on terminal bg between two inactive tabs.
set -wg window-status-format '#[fg=#abb2bf,bg=default,nobold,noitalics,nounderscore]#{?window_zoomed_flag,  , }#W #[fg=#{?#{e|==:#{e|+:#{window_index},1},#{@active_window_index}},#21252b,#5c6370},bg=#{?#{e|==:#{e|+:#{window_index},1},#{@active_window_index}},#3b3f4c,default},nobold,noitalics,nounderscore]#{?#{e|==:#{e|+:#{window_index},1},#{@active_window_index}},,}'
set -wg window-status-current-format '#[fg=#abb2bf,bg=#3b3f4c,nobold,noitalics,nounderscore]#{?window_zoomed_flag,  , }#W #[fg=#3b3f4c,bg=default,nobold,noitalics,nounderscore]'


# Override status-left AFTER the powerline plugin so the session-name's
# trailing cap is conditional: when the first tab is the active one, the
# cap bg becomes the active tab's bg (#3b3f4c) so the colour flows into
# it smoothly; otherwise it rounds off into default like before.
# Same attribute-level-conditional shape as window-status-format above to
# dodge the tmux 3.6 `,,`-unescape bug — see comment block above for why.
set -g status-left '#[fg=#21252b,bg=#98c379] #S #[fg=#98c379,bg=#{?#{==:#{@active_window_index},1},#3b3f4c,default},nobold,noitalics,nounderscore]#[default]'
